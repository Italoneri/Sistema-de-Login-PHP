APP_NAME="Auth Seguro"
APP_ENV=local
APP_KEY=
# Em produção: APP_DEBUG=false é OBRIGATÓRIO — com true, exceptions
# renderizam stack trace pro usuário (vazamento de informação interna).
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Hash de senha (argon2id, OWASP) ---
BCRYPT_ROUNDS=12
HASH_DRIVER=argon2id
ARGON_MEMORY=65536
ARGON_THREADS=1
ARGON_TIME=4

# --- Banco de dados (MySQL/MariaDB via PDO) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=auth_seguro
DB_USERNAME=auth_seguro_app
DB_PASSWORD=

# --- Sessão segura ---
SESSION_DRIVER=database
SESSION_LIFETIME=15
SESSION_EXPIRE_ON_CLOSE=false
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Em produção (servindo via HTTPS) isso DEVE ser true. Só use false em
# dev local sem TLS — cookie 'secure' não é enviado por navegador sobre http.
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=strict

# --- Proteção contra brute force e timeout de inatividade ---
AUTH_INACTIVITY_TIMEOUT_MINUTES=15
BRUTE_FORCE_MAX_ATTEMPTS_EMAIL=5
BRUTE_FORCE_MAX_ATTEMPTS_IP=20
BRUTE_FORCE_WINDOW_MINUTES=15

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
CACHE_STORE=database

# --- E-mail (verificação de cadastro e reset de senha) ---
# Em dev, MAIL_MAILER=log grava o e-mail em storage/logs/laravel.log
# em vez de enviar de verdade.
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="naoresponda@example.com"
MAIL_FROM_NAME="${APP_NAME}"
